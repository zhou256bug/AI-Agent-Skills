# 周报技能凭据模板 —— 复制为 local/credentials.env 后填写（local/credentials.env 已 gitignore，勿提交真实值）
# 也可改用进程环境变量（环境变量优先级高于本文件）。

# ── 取信（必备：收件箱 IMAP）──
WEEKLY_REPORT_IMAP_HOST=imap.qiye.aliyun.com
WEEKLY_REPORT_IMAP_PORT=993
WEEKLY_REPORT_IMAP_USER=your.name@company.com
WEEKLY_REPORT_IMAP_PASSWORD=your-client-auth-password
# 回溯天数（IMAP SINCE）
WEEKLY_REPORT_SINCE_DAYS=10

# ── 业务配置（默认即华智融值，按需覆盖）──
# WEEKLY_REPORT_OWNER=老板
# WEEKLY_REPORT_SENDER_NAME=陈徐伟
# WEEKLY_REPORT_SENDER_EMAIL=evyn.chen@newpostech.com
# WEEKLY_REPORT_SUBJECT_KEY=总裁办及各部门经理周报
# WEEKLY_REPORT_COMPANY=华智融
# WEEKLY_REPORT_ARCHIVE_DIR=~/reports/weekly

# ── 投递：微信 bridge（hermes-weixin，POST /send 有 200/500 回执）──
WEIXIN_BRIDGE_URL=http://localhost:9100
WEIXIN_TO=
# WEIXIN_ACCOUNT_ID=

# ── 投递：企业微信 / 飞书（可选，群机器人 webhook）──
# WECOM_WEBHOOK_URL=
# FEISHU_WEBHOOK_URL=
